local function AddCollapseButton(groupbox)
    local header = groupbox.Holder:FindFirstChildWhichIsA("TextLabel")
    if not header then return end
    
    local btn = Instance.new("ImageButton")
    btn.Size = UDim2.new(0, 20, 0, 20)
    btn.Position = UDim2.new(1, 5, 0, 7)
    btn.BackgroundTransparency = 1
    btn.Parent = header
    
    local chevronDown = Library:GetIcon("chevron-down")
    local chevronRight = Library:GetIcon("chevron-right")
    
    btn.Image = chevronDown.Url
    btn.ImageRectOffset = chevronDown.ImageRectOffset
    btn.ImageRectSize = chevronDown.ImageRectSize
    
    local collapsed = false
    local container = groupbox.Container
    local holder = groupbox.Holder
    
    header.Size = UDim2.new(1, -50, 0, 34)
    
    btn.MouseButton1Click:Connect(function()
        collapsed = not collapsed
        
        if collapsed then
            container.Visible = false
            holder.Size = UDim2.new(1, 0, 0, 34)
            btn.Image = chevronRight.Url
            btn.ImageRectOffset = chevronRight.ImageRectOffset
            btn.ImageRectSize = chevronRight.ImageRectSize
        else
            container.Visible = true
            groupbox:Resize()
            btn.Image = chevronDown.Url
            btn.ImageRectOffset = chevronDown.ImageRectOffset
            btn.ImageRectSize = chevronDown.ImageRectSize
        end
    end)
end

for _, tab in pairs(Library.Tabs) do
    for _, group in pairs(tab.Groupboxes or {}) do
        pcall(AddCollapseButton, group)
    end
end

