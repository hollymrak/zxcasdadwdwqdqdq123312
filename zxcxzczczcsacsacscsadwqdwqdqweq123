MainModule.ToggleInfiniteStamina = function(enabled)
    local toggleRef = ToggleRefs.InfiniteStamina
    
    if enabled then
        if not MainModule.CanEnableToggle("HideAndSeek", "Infinite Stamina", toggleRef) then
            return false
        end
    end
    
    if enabled then
        if MainModule.InfStaminaActive then return end
        MainModule.InfStaminaActive = true
        local function freezeUI()
            local ui = ReplicatedStorage:FindFirstChild("UI")
            if ui then
                local sb = ui:FindFirstChild("StaminaBar")
                local nsb = ui:FindFirstChild("NoRegenStaminaBar")
                if sb then
                    sb.Size = UDim2.new(1,0,1,0)
                    table.insert(MainModule.StaminaConns, sb:GetPropertyChangedSignal("Size"):Connect(function() if sb.Size.X.Scale < 1 then sb.Size = UDim2.new(1,0,1,0) end end))
                end
                if nsb then
                    nsb.Size = UDim2.new(1,0,1,0)
                    table.insert(MainModule.StaminaConns, nsb:GetPropertyChangedSignal("Size"):Connect(function() if nsb.Size.X.Scale < 1 then nsb.Size = UDim2.new(1,0,1,0) end end))
                end
            end
        end
        local function freezeChar()
            local c = LocalPlayer.Character
            if not c then return end
            local h = c:FindFirstChild("Humanoid")
            if not h then return end
            for _,ch in pairs(h:GetChildren()) do
                if ch:IsA("NumberValue") and (ch.Name:lower():find("stamina") or ch.Name:lower():find("energy")) then
                    ch.Value = 100
                    table.insert(MainModule.StaminaConns, ch:GetPropertyChangedSignal("Value"):Connect(function() ch.Value = 100 end))
                end
            end
            for _,ch in pairs(c:GetChildren()) do
                if ch:IsA("NumberValue") and (ch.Name:lower():find("stamina") or ch.Name:lower():find("energy")) then
                    ch.Value = 100
                    table.insert(MainModule.StaminaConns, ch:GetPropertyChangedSignal("Value"):Connect(function() ch.Value = 100 end))
                end
            end
        end
        freezeUI()
        freezeChar()
        table.insert(MainModule.StaminaConns, LocalPlayer.CharacterAdded:Connect(function() task.wait(0.5); if MainModule.InfStaminaActive then freezeChar() end end))
        table.insert(MainModule.StaminaConns, RunService.Heartbeat:Connect(function()
            if MainModule.InfStaminaActive then
                local c = LocalPlayer.Character
                if c then
                    local h = c:FindFirstChild("Humanoid")
                    if h then
                        for _,ch in pairs(h:GetChildren()) do
                            if ch:IsA("NumberValue") and (ch.Name:lower():find("stamina") or ch.Name:lower():find("energy")) and ch.Value < 100 then
                                ch.Value = 100
                            end
                        end
                    end
                end
                local ui = ReplicatedStorage:FindFirstChild("UI")
                if ui then
                    local sb = ui:FindFirstChild("StaminaBar")
                    local nsb = ui:FindFirstChild("NoRegenStaminaBar")
                    if sb and sb.Size.X.Scale < 1 then sb.Size = UDim2.new(1,0,1,0) end
                    if nsb and nsb.Size.X.Scale < 1 then nsb.Size = UDim2.new(1,0,1,0) end
                end
            end
        end))
        MainModule.Notify("Infinite Stamina","Enabled",3)
    else
        MainModule.InfStaminaActive = false
        for _,c in pairs(MainModule.StaminaConns) do pcall(function() c:Disconnect() end) end
        MainModule.StaminaConns = {}
        -- MainModule.Notify("Infinite Stamina","Disabled",3)
    end
    MainModule.PlayBell()
    return true
end

