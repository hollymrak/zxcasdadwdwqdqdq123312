function MainModule.FreezeHealth()
    local character = MainModule.GetCharacter()
    if not character then return end
    
    local humanoid = MainModule.GetHumanoid(character)
    if not humanoid then return end
    
    if MainModule.JumpRopeAntiHit.HealthConnection then
        MainModule.JumpRopeAntiHit.HealthConnection:Disconnect()
    end
    
    MainModule.JumpRopeAntiHit.OriginalBreakJoints = humanoid.BreakJointsOnDeath
    humanoid.BreakJointsOnDeath = false
    MainModule.JumpRopeAntiHit.OriginalHealth = humanoid.Health
    
    MainModule.JumpRopeAntiHit.HealthConnection = humanoid:GetPropertyChangedSignal("Health"):Connect(function()
        if MainModule.JumpRopeAntiHit.Enabled and humanoid.Health < MainModule.JumpRopeAntiHit.OriginalHealth then
            humanoid.Health = MainModule.JumpRopeAntiHit.OriginalHealth
        end
    end)
end

function MainModule.SetupJumpRopeAntiHit()
    local character = MainModule.GetCharacter()
    if not character then return end
    
    local humanoid = MainModule.GetHumanoid(character)
    if not humanoid then return end
    
    MainModule.JumpRopeAntiHit.WasJumping = false
    
    if MainModule.JumpRopeAntiHit.HealthConnection then
        MainModule.JumpRopeAntiHit.HealthConnection:Disconnect()
    end
    
    humanoid.StateChanged:Connect(function(oldState, newState)
        if not MainModule.JumpRopeAntiHit.Enabled then return end
        
        if newState == Enum.HumanoidStateType.Jumping then
            MainModule.JumpRopeAntiHit.WasJumping = true
        end
        
        if MainModule.JumpRopeAntiHit.WasJumping and (newState == Enum.HumanoidStateType.Running or 
           newState == Enum.HumanoidStateType.Landed or
           newState == Enum.HumanoidStateType.GettingUp) then
            MainModule.PlayLandAnimation()
            MainModule.JumpRopeAntiHit.WasJumping = false
        end
    end)
    
    MainModule.FreezeHealth()
end

function MainModule.ToggleJumpRopeAntiHit(enabled)
    local toggleRef = ToggleRefs.JumpRopeAntiHit
    
    if enabled then
        if not MainModule.CanEnableToggle("JumpRope", "AntiHit + Balance", toggleRef) then
            return false
        end
    end
    
    if MainModule.JumpRopeAntiHit.Connection then
        MainModule.JumpRopeAntiHit.Connection:Disconnect()
        MainModule.JumpRopeAntiHit.Connection = nil
    end
    
    if MainModule.JumpRopeAntiHit.HealthConnection then
        MainModule.JumpRopeAntiHit.HealthConnection:Disconnect()
        MainModule.JumpRopeAntiHit.HealthConnection = nil
    end
    
    if MainModule.JumpRopeAntiHit.CurrentAnimation then
        pcall(function() MainModule.JumpRopeAntiHit.CurrentAnimation:Stop() end)
        MainModule.JumpRopeAntiHit.CurrentAnimation = nil
    end
    
    if MainModule.JumpRopeAntiHit.StopTimer then
        MainModule.JumpRopeAntiHit.StopTimer:Disconnect()
        MainModule.JumpRopeAntiHit.StopTimer = nil
    end
    
    MainModule.JumpRopeAntiHit.Enabled = enabled
    MainModule.JumpRopeAntiHit.RopeDestroyed = false
    
    if enabled then
        MainModule.DisableDamageScripts()
        MainModule.DestroyAllRopes()
        MainModule.SetupJumpRopeAntiHit()
        
        local character = MainModule.GetCharacter()
        if character then
            local humanoid = MainModule.GetHumanoid(character)
            if humanoid then
                humanoid.BreakJointsOnDeath = false
            end
        end
        
        MainModule.JumpRopeAntiHit.Connection = RunService.Heartbeat:Connect(function()
            if not MainModule.JumpRopeAntiHit.Enabled then return end
            
            if not MainModule.IsGameActive("JumpRope") then
                if ToggleRefs.JumpRopeAntiHit then
                    pcall(function() ToggleRefs.JumpRopeAntiHit:SetValue(false) end)
                end
                MainModule.ToggleJumpRopeAntiHit(false)
                return
            end
            
            if not MainModule.JumpRopeAntiHit.RopeDestroyed then
                MainModule.DestroyAllRopes()
            end
            
            local character = MainModule.GetCharacter()
            if character then
                local humanoid = MainModule.GetHumanoid(character)
                if humanoid and MainModule.JumpRopeAntiHit.OriginalHealth then
                    if humanoid.Health < MainModule.JumpRopeAntiHit.OriginalHealth then
                        humanoid.Health = MainModule.JumpRopeAntiHit.OriginalHealth
                    end
                    humanoid.BreakJointsOnDeath = false
                end
            end
        end)
        
        Library.Notify("JumpRope", "AntiHit + Balance Enabled", 3)
    else
        MainModule.JumpRopeAntiHit.OriginalHealth = nil
        
        local character = MainModule.GetCharacter()
        if character then
            local humanoid = MainModule.GetHumanoid(character)
            if humanoid and MainModule.JumpRopeAntiHit.OriginalBreakJoints ~= nil then
                humanoid.BreakJointsOnDeath = MainModule.JumpRopeAntiHit.OriginalBreakJoints
            end
        end
        
        -- MainModule.Notify("JumpRope", "AntiHit + Balance Disabled", 2)
    end
    
    MainModule.PlayBell()
    return true
end

